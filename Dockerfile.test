FROM erlang:22.3.4.26

WORKDIR /opt/snatch

# Mirror executor localbuilder base handling for old Debian repos.
RUN sed -i 's|http://deb.debian.org/debian|http://archive.debian.org/debian|g' /etc/apt/sources.list && \
    sed -i 's|http://security.debian.org/debian-security|http://archive.debian.org/debian-security|g' /etc/apt/sources.list && \
    sed -i '/stretch-updates/d' /etc/apt/sources.list

# Needed for git-based rebar deps and native deps.
RUN apt-get update \
    && apt-get install -y --no-install-recommends \
       git ca-certificates build-essential \
    && rm -rf /var/lib/apt/lists/*

# Copy project files
COPY rebar.config rebar.lock ./
COPY src ./src
COPY include ./include
COPY test ./test

# Fetch deps and compile
RUN rebar3 compile

# Exclude claws_kafka_tests (requires brod dep not in rebar.config)
RUN rm -f test/claws_kafka_tests.erl

CMD ["rebar3", "eunit", "--verbose"]
